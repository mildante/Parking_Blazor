@page "/auth"
@using Parking_Blazor.ApiRequests.Models
@using Parking_Blazor.ApiRequests.Services
@using static Parking_Blazor.ApiRequests.Models.User

@inject UserRequests UserRequests
@inject UserService UserService
@inject NavigationManager Navigation

<PageTitle>Авторизация</PageTitle>

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-tabs">
            <button class="auth-tab @(isLogin ? "active" : "")" @onclick="ShowLogin">
                Вход
            </button>

            <button class="auth-tab @(!isLogin ? "active" : "")" @onclick="ShowRegistration">
                Регистрация
            </button>
        </div>

        @if (isLogin)
        {
            <div class="auth-form">
                <h2>Вход в систему</h2>
                <p>Введите данные для авторизации</p>

                <div class="form-group">
                    <label>Почта</label>
                    <input class="auth-input" type="email" @bind="authModel.email" />
                </div>

                <div class="form-group">
                    <label>Пароль</label>
                    <input class="auth-input" type="password" @bind="authModel.password" />
                </div>

                <button class="auth-btn" @onclick="Login">
                    Войти
                </button>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="auth-message @(isSuccess ? "success" : "error")">
                        @message
                    </div>
                }
            </div>
        }
        else
        {
            <div class="auth-form">
                <h2>Регистрация</h2>
                <p>Создайте аккаунт для использования парковки</p>

                <div class="form-row">
                    <div class="form-group">
                        <label>Имя</label>
                        <input class="auth-input" type="text" @bind="registerModel.name" />
                    </div>

                    <div class="form-group">
                        <label>Фамилия</label>
                        <input class="auth-input" type="text" @bind="registerModel.surname" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Почта</label>
                    <input class="auth-input" type="email" @bind="registerModel.email" />
                </div>

                <div class="form-group">
                    <label>Телефон</label>
                    <input class="auth-input" type="text" @bind="registerModel.phone" />
                </div>

                <div class="form-group">
                    <label>Пароль</label>
                    <input class="auth-input" type="password" @bind="registerModel.password" />
                </div>

                <button class="auth-btn" @onclick="Registration">
                    Зарегистрироваться
                </button>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="auth-message @(isSuccess ? "success" : "error")">
                        @message
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private bool isLogin = true;
    private bool isSuccess = false;
    private string? message;

    private AuthUserRequest authModel = new();
    private UserModel registerModel = new()
    {
        role_id = 3
    };

    private void ShowLogin()
    {
        isLogin = true;
        message = null;
    }

    private void ShowRegistration()
    {
        isLogin = false;
        message = null;
    }

    private async Task Login()
    {
        message = null;

        var result = await UserRequests.AuthUser(authModel);

        if (result == null)
        {
            isSuccess = false;
            message = "Ошибка подключения к серверу";
            return;
        }

        if (!result.status)
        {
            isSuccess = false;
            message = result.message;
            return;
        }

        UserService.CurrentUser = result.user;
        UserService.Notify();

        isSuccess = true;
        message = result.message ?? "Вход выполнен";

        Navigation.NavigateTo("/profile");
    }

    private async Task Registration()
    {
        message = null;

        registerModel.role_id = 3;

        var result = await UserRequests.RegistrationUser(registerModel);

        if (result == null)
        {
            isSuccess = false;
            message = "Ошибка подключения к серверу";
            return;
        }

        if (!result.status)
        {
            isSuccess = false;
            message = result.message;
            return;
        }

        isSuccess = true;
        message = result.message ?? "Регистрация выполнена";

        isLogin = true;
        authModel.email = registerModel.email;
    }
}