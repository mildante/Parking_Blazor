@page "/auth"
@using Parking_Blazor.ApiRequests.Models
@using Parking_Blazor.ApiRequests.Services
@using static Parking_Blazor.ApiRequests.Models.User

@inject UserRequests UserRequests
@inject UserService UserService
@inject NavigationManager Navigation

<PageTitle>Авторизация</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-visual">
            <span class="profile-pill">Parking app</span>
            <h1>Добро пожаловать</h1>
            <p>Войдите в аккаунт или зарегистрируйтесь, чтобы управлять своими машинами и парковочными данными.</p>

            <div class="auth-accent-card">
                <div>
                    <span>Статус</span>
                    <h3>Свободная парковка</h3>
                </div>
                <div class="auth-accent-circle">
                    <i class="bi bi-car-front-fill"></i>
                </div>
            </div>
        </div>

        <div class="auth-form-card">
            <div class="auth-tabs">
                <button class="auth-tab @(isLogin ? "active" : "")" @onclick="ShowLogin">
                    Вход
                </button>
                <button class="auth-tab @(!isLogin ? "active" : "")" @onclick="ShowRegistration">
                    Регистрация
                </button>
            </div>

            @if (isLogin)
            {
                <div class="card-title">
                    <h2>Вход в систему</h2>
                    <p>Введите данные для авторизации</p>
                </div>

                <div class="form-group full">
                    <label>Почта</label>
                    <input class="profile-input" @bind="authModel.email" />
                </div>

                <div class="form-group full">
                    <label>Пароль</label>
                    <input class="profile-input" type="password" @bind="authModel.password" />
                </div>

                <button class="primary-btn auth-submit" @onclick="Login">
                    Войти
                </button>
            }
            else
            {
                <div class="card-title">
                    <h2>Регистрация</h2>
                    <p>Создайте аккаунт для использования парковки</p>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Имя</label>
                        <input class="profile-input" @bind="registerModel.name" />
                    </div>

                    <div class="form-group">
                        <label>Фамилия</label>
                        <input class="profile-input" @bind="registerModel.surname" />
                    </div>

                    <div class="form-group full">
                        <label>Почта</label>
                        <input class="profile-input" @bind="registerModel.email" />
                    </div>

                    <div class="form-group full">
                        <label>Телефон</label>
                        <input class="profile-input" @bind="registerModel.phone" />
                    </div>

                    <div class="form-group full">
                        <label>Пароль</label>
                        <input class="profile-input" type="password" @bind="registerModel.password" />
                    </div>
                </div>

                <button class="primary-btn auth-submit" @onclick="Registration">
                    Зарегистрироваться
                </button>
            }

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="profile-message @(isSuccess ? "success" : "error") auth-message">
                    @message
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isLogin = true;
    private bool isSuccess = false;
    private string? message;

    private AuthUserRequest authModel = new();

    private UserModel registerModel = new()
    {
        role_id = 3
    };

    protected override async Task OnInitializedAsync()
    {
        await UserRequests.LoadUserFromToken();

        if (UserService.CurrentUser != null)
            Navigation.NavigateTo("/", replace: true);
    }

    private void ShowLogin()
    {
        isLogin = true;
        message = null;
    }

    private void ShowRegistration()
    {
        isLogin = false;
        message = null;
    }

    private async Task Login()
    {
        message = null;

        var result = await UserRequests.GetAuthorizeUser(authModel);

        if (result == null)
        {
            isSuccess = false;
            message = "Ошибка подключения к серверу";
            return;
        }

        if (!result.status)
        {
            isSuccess = false;
            message = result.message;
            return;
        }

        UserService.CurrentUser = result.user;
        UserService.Notify();

        isSuccess = true;
        message = result.message ?? "Вход выполнен";

        Navigation.NavigateTo("/profile");
    }

    private async Task Registration()
    {
        message = null;
        registerModel.role_id = 3;

        var result = await UserRequests.RegistrationUser(registerModel);

        if (result == null)
        {
            isSuccess = false;
            message = "Ошибка подключения к серверу";
            return;
        }

        if (!result.status)
        {
            isSuccess = false;
            message = result.message;
            return;
        }

        isSuccess = true;
        message = result.message ?? "Регистрация выполнена";

        isLogin = true;
        authModel.email = registerModel.email;
    }
}
