@implements IDisposable
@using Parking_Blazor.ApiRequests.Models
@using Parking_Blazor.ApiRequests.Services
@inject UserService UserService
@inject UserRequests UserRequests

<div class="container-fluid">
    <a class="navbar-brand parking-brand" href="">Parking</a>

    <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Главная
            </NavLink>
        </div>

        @if (UserService.CurrentUser == null)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="auth">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Авторизация
                </NavLink>
            </div>
        }

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="profile">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Профиль
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="subscriptions">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Абонементы
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="parking-history">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> История парковок
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin-parking">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Админ-панель
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin-reports">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Отчеты
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        UserService.OnAuthStateChanged += StateHasChanged;
        await UserRequests.LoadUserFromToken();
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    public void Dispose()
    {
        UserService.OnAuthStateChanged -= StateHasChanged;
    }
}
